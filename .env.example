# HushTales Frontend — copy to .env.local and fill in values

# API Gateway (REST) base URL
NEXT_PUBLIC_API_BASE_URL=

# Rate-limiting key (x-api-key header — not a secret)
NEXT_PUBLIC_API_KEY=

# Cognito
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_HOSTED_UI=
