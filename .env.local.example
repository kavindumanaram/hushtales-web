# HushTales — copy this file to .env.local and fill in the Lambda URLs
# Get real URLs from: aws cloudformation describe-stacks --stack-name hushtales-dev --region ap-southeast-2

# POST { character, theme, child_name, user_id, mode } → { job_id, story_text, mode }
# Not yet implemented — leave blank until deployed
NEXT_PUBLIC_STORY_GENERATOR_URL=

# POST { script_text, user_id } → { job_id }
NEXT_PUBLIC_SUBMIT_URL=

# GET → StoryJob[]
NEXT_PUBLIC_GET_JOBS_URL=

# GET → VoiceProfile[]
NEXT_PUBLIC_LIST_VOICES_URL=

# GET → { status, heygen_voice_id }
# Not yet deployed — leave blank until CheckVoiceFunctionUrl is in stack outputs
NEXT_PUBLIC_CHECK_VOICE_URL=

# GET ?user_id=xxx → { upload_url, s3_key }
NEXT_PUBLIC_GET_UPLOAD_URL=

# GET ?user_id=xxx → { deleted }
NEXT_PUBLIC_DELETE_VOICE_URL=

# Hardcoded until Cognito auth is wired up
NEXT_PUBLIC_ACTIVE_USER_ID=user_test_001
